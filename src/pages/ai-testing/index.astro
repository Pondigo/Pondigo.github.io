  <Footer>QA Functional POC | March 24, 2026<br>20+ references · 15 papers with PDF · 7 sections · Trader flows</Footer>

  <Fragment slot="page-scripts">
    <script is:inline>
      // Kanban drag & drop
      function allowDrop(e) { e.preventDefault(); e.currentTarget.classList.add('drag-over'); }
      function drag(e) { e.dataTransfer.setData('text', e.target.id); e.target.classList.add('dragging'); }
      function drop(e) {
        e.preventDefault();
        e.currentTarget.classList.remove('drag-over');
        var id = e.dataTransfer.getData('text');
        var el = document.getElementById(id);
        if (el) { el.classList.remove('dragging'); e.currentTarget.appendChild(el); }
      }
      document.querySelectorAll('.kanban-col').forEach(function(col) {
        col.addEventListener('dragleave', function(e) { e.currentTarget.classList.remove('drag-over'); });
        col.addEventListener('dragend', function() {
          document.querySelectorAll('.kanban-card.dragging').forEach(function(c) { c.classList.remove('dragging'); });
          document.querySelectorAll('.kanban-col.drag-over').forEach(function(c) { c.classList.remove('drag-over'); });
        });
      });

      // Auto-resize textarea
      function autoResize(el) {
        el.style.height = 'auto';
        el.style.height = el.scrollHeight + 'px';
      }

      // Add card modal
      var cardCounter = 0;
      function openAddCard() {
        document.getElementById('addCardModal').classList.add('open');
        document.getElementById('cardLabel').value = '';
        document.getElementById('cardDesc').value = '';
        document.getElementById('cardLabel').focus();
      }
      function closeAddCard(e) {
        if (e && e.target !== e.currentTarget) return;
        document.getElementById('addCardModal').classList.remove('open');
      }
      function addCard() {
        var label = document.getElementById('cardLabel').value.trim();
        var desc = document.getElementById('cardDesc').value.trim();
        var phase = document.getElementById('cardPhase').value;
        if (!label || !desc) return;
        cardCounter++;
        var card = document.createElement('div');
        card.className = 'kanban-card';
        card.draggable = true;
        card.id = 'k-custom-' + cardCounter;
        card.setAttribute('ondragstart', 'drag(event)');
        card.innerHTML = '<span class="kanban-label">' + label + '</span> ' + desc;
        document.getElementById(phase).appendChild(card);
        closeAddCard();
      }
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeAddCard();
        if (e.key === 'Enter' && document.getElementById('addCardModal').classList.contains('open')) addCard();
      });
    </script>
  </Fragment>
</PaperLayout>
